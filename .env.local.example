# =============================================
# AI Provider — choose ONE (or more, priority: Groq > Anthropic > Gemini)
# =============================================

# OPTION 1 — FREE (RECOMMENDED): Groq
# No credit card, no billing. ~30 requests/min, plenty for a full 67-game sim.
# Get your free key at https://console.groq.com — sign in, go to API Keys
GROQ_API_KEY=your_groq_api_key_here

# OPTION 2 — FREE (limited): Google Gemini
# Free key at https://aistudio.google.com/app/apikey
# Note: free tier is 20 requests/day for this model — enough for a single sim
# GEMINI_API_KEY=your_gemini_api_key_here

# OPTION 3 — Paid: Anthropic Claude
# Get your key at https://console.anthropic.com/
# Uses claude-haiku-4-5 (~$0.03 per full 67-game simulation)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
